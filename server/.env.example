# --- Base de datos (PostgreSQL) ---
DB_NAME=dndworld
DB_USER=postgres
DB_PASS=tu_password
DB_HOST=localhost

# --- Auth ---
JWT_SECRET=cambia_esto_por_un_secreto_largo

# --- Servidor ---
PORT=3001

# --- Cloudinary (almacenamiento de imágenes) ---
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- OpenAI (render del héroe con equipo, gpt-image-1) ---
# Necesaria para el botón "Sincronizar héroe". Sin esto, el endpoint
# /api/characters/:id/render devuelve 503.
OPENAI_API_KEY=sk-...

# --- DM Assistant (conversacion + tools) ---
# Modelo sugerido para interpretar lenguaje natural del DM y decidir uso de tools.
DM_ASSISTANT_MODEL=gpt-4o-mini
